APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging: debug in local; use daily + warning/info in staging/production
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_CHANNEL=daily
# LOG_LEVEL=warning

# Per-IP attempts per minute for POST /login (central) and POST auth/login (tenant)
LOGIN_RATE_LIMIT_PER_MINUTE=10

DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_SCHEMA=public

# Comma-separated hostnames for the central app (same pattern as inventory-management-backend)
CENTRAL_DOMAIN=app.localhost,localhost,127.0.0.1

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# null = no persistence (recommended). database/redis require compatible drivers; Redis supports Stancl cache tags if you re-enable CacheTenancyBootstrapper.
CACHE_STORE=null
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# REDIS_DB: general/default Redis logical DB; REDIS_CACHE_DB: used by CACHE_STORE=redis (see config/cache.php)
# REDIS_CLIENT: phpredis (PHP extension) or predis (composer — works without extension)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AUDITING_ENABLED=true

# Comma-separated hosts for Sanctum SPA cookie auth (e.g. frontend dev server)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,app.localhost,app.localhost:3000
